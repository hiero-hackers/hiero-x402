# hiero-x402 demo — testnet ONLY (the code refuses anything else).
# Two funded testnet accounts (facilitator + agent): https://portal.hedera.com/faucet
# plus a third account id that only RECEIVES (no key, no funding needed).
# Keys: paste whatever form the Portal shows — each key is verified against
# the account's on-chain key at startup, so curve/encoding never bites.
# PAY_TO_ACCOUNT must be a THIRD account, different from the facilitator:
# if the fee payer also receives, the mirror nets its fee against the payment
# and the verifier will honestly report "underpaid by exactly the fee".
# (We know because it happened — see README.)

# facilitator (fee payer — co-signs and submits; holds a key)
FACILITATOR_ACCOUNT_ID=0.0.xxxx
FACILITATOR_PRIVATE_KEY=

# resource server (NO key — account id only, receives the payments; NOT the facilitator)
PAY_TO_ACCOUNT=0.0.yyyy
FACILITATOR_URL=http://localhost:4020

# agent (the payer; holds the other key)
AGENT_ACCOUNT_ID=0.0.zzzz
AGENT_PRIVATE_KEY=
SERVER_URL=http://localhost:4021
RESOURCE=/data/spot-price
SYMBOL=HBAR

# USDC route (/data/fx): the agent account must HOLD testnet USDC
# (token 0.0.429274 — the official id from @x402/hedera) and PAY_TO_ACCOUNT
# must be associated with it; the facilitator preflight refuses cleanly
# otherwise. Select it with RESOURCE=/data/fx. HBAR routes need none of this.

# facilitator policy (optional): which requirements this fee payer sponsors.
# ALLOWED_PAY_TO: comma-separated account ids; empty = any.
# MAX_AMOUNT: cap in the offered asset's ATOMIC units; empty = no cap.
ALLOWED_PAY_TO=
MAX_AMOUNT=

# server (optional): withhold data until the settlement VERIFIES on the
# public mirror (adds seconds of honest latency per paid request).
VERIFY_BEFORE_SERVE=0

# agent HCS attestation (optional): write each verified verdict to a Hedera
# Consensus Service topic — an append-only public audit log. Set an existing
# topic id, or the literal "create" to make one (the run prints the new id).
# Empty = off. Costs a fraction of a cent per message.
ATTEST_TOPIC_ID=

# optional overrides (defaults shown — safe to delete this whole section)
X402_NETWORK=hedera:testnet
FACILITATOR_PORT=4020
SERVER_PORT=4021
RECEIPT_PATH=receipt.html
CHECKOUT_BASE=https://hiero-hackers.github.io/hiero-checkout/
